#!/usr/bin/env bash
# loongClaw 自定义指令入口：loongclaw dev-py | start-py [--bg] | pack-py | push-py | push-all | setup
# 需在项目根目录执行，或将项目根加入 PATH 后直接执行 loongclaw。

set -e
VERSION="0.1.0"
ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"
# 是否在 build 目录（在 build 下执行 ./loongclaw start 时无 scripts/pack-py.sh）
IN_BUILD=false
[ ! -f "$ROOT/scripts/pack-py.sh" ] && IN_BUILD=true
BACKEND="${ROOT}/backend-py"

# 启动逻辑（原 start.sh）：使用 uv 创建环境、安装依赖并启动 main.py
run_start() {
  if ! command -v uv >/dev/null 2>&1; then
    echo "未检测到 uv，开始自动安装..."
    if ! command -v curl >/dev/null 2>&1; then
      echo "未找到 curl，尝试先安装 curl..."
      if command -v apt-get >/dev/null 2>&1; then
        apt-get update -qq && apt-get install -y -qq curl || true
      elif command -v apk >/dev/null 2>&1; then
        apk add --no-cache curl 2>/dev/null || true
      elif command -v dnf >/dev/null 2>&1; then
        dnf install -y curl 2>/dev/null || true
      elif command -v yum >/dev/null 2>&1; then
        yum install -y curl 2>/dev/null || true
      fi
    fi
    if ! command -v curl >/dev/null 2>&1; then
      echo "无法安装 curl，请先在系统中安装 curl 或预装 uv。"
      exit 1
    fi
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$PATH"
    if ! command -v uv >/dev/null 2>&1; then
      echo "uv 安装后仍不可用，请检查 PATH（建议加入 ~/.local/bin）"
      exit 1
    fi
  fi

  if [ ! -x ".venv/bin/python" ]; then
    echo "创建虚拟环境 .venv..."
    uv venv .venv
  fi

  VENV_PY=".venv/bin/python"

  if [ -f "pyproject.toml" ]; then
    echo "安装依赖 (uv sync)..."
    uv sync
  else
    echo "未找到 pyproject.toml，请在项目根或执行 loongclaw pack-py 后的 build 目录下运行。"
    exit 1
  fi

  if [ -z "${OPENAI_API_KEY}" ] && [ -f ".env" ]; then
    _val=$(grep -E '^\s*OPENAI_API_KEY\s*=' .env 2>/dev/null | head -1 | sed 's/^[^=]*=//' | sed "s/^[\"']//;s/[\"']$//")
    [ -n "${_val}" ] && export OPENAI_API_KEY="${_val}"
    unset _val
  fi

  # 当前目录为 backend-py 或 build；build 下前端在 ./frontend，backend-py 下在 ../frontend
  if [ -f "frontend/package.json" ]; then FRONTEND_DPATH="frontend"; else FRONTEND_DPATH="../frontend"; fi
  if [ ! -d "$FRONTEND_DPATH/dist" ] && [ -f "$FRONTEND_DPATH/package.json" ]; then
    echo "前端尚未构建，开始 pnpm install && pnpm build..."
    if command -v pnpm >/dev/null 2>&1; then
      (cd "$FRONTEND_DPATH" && pnpm install --frozen-lockfile 2>/dev/null || pnpm install && pnpm build)
    elif command -v npm >/dev/null 2>&1; then
      (cd "$FRONTEND_DPATH" && npm ci 2>/dev/null || npm install && npm run build)
    else
      echo "警告: 未找到 pnpm/npm，跳过前端构建。请手动执行 cd frontend && pnpm build"
    fi
  fi

  echo "启动 main.py..."
  if [ "${1:-}" = "bg" ]; then
    nohup "$VENV_PY" main.py >> loongclaw.log 2>&1 &
    echo "已后台启动，PID: $!"
    echo "日志: $(pwd)/loongclaw.log"
    exit 0
  fi
  exec "$VENV_PY" main.py
}

case "${1:-}" in
  -V|--version)
    echo "loongclaw $VERSION"
    exit 0
    ;;
  -h|--help)
    echo "用法: loongclaw [-V|--version] [-h|--help] dev-py | setup | start-py ] | pack-py | push-py | push-all"
    echo "  setup     - 将项目根加入 PATH（写入 ~/.zshrc），之后可在任意目录使用 loongclaw"
    echo "  start-py  - 启动（前台）；start-py 后台启动，日志写入 loongclaw.log"
    if [ "$IN_BUILD" = false ]; then
      echo "  dev-py    - 先打包前端 (frontend/dist)，再启动后端 main.py（scripts/dev-py.sh）"
      echo "  pack-py   - 混淆并打包到 build/（scripts/pack-py.sh）"
      echo "  push-py   - 对 build/ 执行 git init、提交并推送到 GitHub（scripts/push-py.sh）"
      echo "  push-all  - 一键推送项目根仓库到 openclaw（可用 OPENCLAW_REPO_URL 覆盖）"
    fi
    exit 0
    ;;
  dev-py)
    if [ "$IN_BUILD" = true ]; then
      echo "没有 dev-py 命令（请在项目根执行）。"
      exit 1
    fi
    exec bash "$ROOT/scripts/dev-py.sh"
    ;;
  start-py)
    _bg=""
    [ "${2:-}" = "--bg" ] && _bg="bg"
    if [ "$IN_BUILD" = true ]; then
      run_start $_bg
    else
      if [ -f "$BACKEND/build/main.py" ]; then
        cd "$BACKEND/build"
      elif [ -f "$BACKEND/main.py" ]; then
        cd "$BACKEND"
      else
        echo "未找到 main.py（backend-py/ 与 backend-py/build/ 均无），请先执行: loongclaw pack-py"
        exit 1
      fi
      run_start $_bg
    fi
    ;;
  pack-py)
    exec bash "$ROOT/scripts/pack-py.sh"
    ;;
  push-py)
    exec bash "$ROOT/scripts/push-py.sh"
    ;;
  push-all)
    # 一键推送项目根仓库到 https://github.com/1bnb/openclaw.git
    if [ "$IN_BUILD" = true ]; then
      echo "请在项目根目录执行 loongclaw push-all。"
      exit 1
    fi
    cd "$ROOT"
    OPENCLAW_REPO="${OPENCLAW_REPO_URL:-https://github.com/1bnb/openclaw.git}"
    if ! git remote get-url openclaw &>/dev/null; then
      git remote add openclaw "$OPENCLAW_REPO"
    else
      git remote set-url openclaw "$OPENCLAW_REPO"
    fi
    echo "推送到 $OPENCLAW_REPO ..."
    git push -u openclaw main --force 2>/dev/null || git push -u openclaw HEAD:main --force
    ;;
  setup)
    ZSHRC="${HOME}/.zshrc"
    LINE="export PATH=\"${ROOT}:\$PATH\""
    if [ -f "$ZSHRC" ] && grep -qF "$ROOT" "$ZSHRC" 2>/dev/null; then
      echo "PATH 中已包含本项目，无需重复添加。"
    else
      echo "" >> "$ZSHRC"
      echo "# loongClaw: 在任意目录执行 loongclaw 命令" >> "$ZSHRC"
      echo "$LINE" >> "$ZSHRC"
      echo "已将项目根路径添加到 $ZSHRC，请执行 'source $ZSHRC' 立即生效。"
    fi
    ;;
  *)
    echo "用法: loongclaw [-V|--version] [-h|--help] dev-py | setup | start-py | pack-py | push-py | push-all"
    echo "  setup     - 将项目根加入 PATH（写入 ~/.zshrc），之后可在任意目录使用 loongclaw"
    echo "  start-py  - 启动（前台）；start-py 后台启动，日志写入 loongclaw.log"
    if [ "$IN_BUILD" = false ]; then
      echo "  dev-py    - 先打包前端 (frontend/dist)，再启动后端 main.py（scripts/dev-py.sh）"
      echo "  pack-py   - 混淆并打包到 build/（scripts/pack-py.sh）"
      echo "  push-py   - 对 build/ 执行 git init、提交并推送到 GitHub（scripts/push-py.sh）"
      echo "  push-all  - 一键推送项目根仓库到 openclaw（可用 OPENCLAW_REPO_URL 覆盖）"
    fi
    echo "使用 loongclaw --help 查看完整说明。"
    exit 1
    ;;
esac
